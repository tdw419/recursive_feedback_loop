# RFL Autoresearch Experiment Analysis

Analyze `results.tsv` to track how experiments improve the RFL over time.

```python
import pandas as pd
import matplotlib.pyplot as plt
import numpy as np

df = pd.read_csv("results.tsv", sep="\t")
print(f"Total experiments: {len(df)}")
print(f"Columns: {list(df.columns)}")
df.head(10)
```

```python
# Status breakdown
counts = df["status"].value_counts()
print("Experiment outcomes:")
print(counts.to_string())

n_keep = counts.get("keep", 0)
n_discard = counts.get("discard", 0)
n_decided = n_keep + n_discard
if n_decided > 0:
    print(f"\nKeep rate: {n_keep}/{n_decided} = {n_keep / n_decided:.1%}")
```

```python
# Composite score over time
fig, ax = plt.subplots(figsize=(14, 6))

valid = df[df["status"] != "crash"].reset_index(drop=True)
baseline = valid.loc[0, "composite_score"]

# Discarded as faint dots
disc = valid[valid["status"] == "discard"]
ax.scatter(disc.index, disc["composite"], c="#cccccc", s=20, alpha=0.5, label="Discarded")

# Kept as green dots
kept = valid[valid["status"] == "keep"]
ax.scatter(kept.index, kept["composite"], c="#2ecc71", s=60, edgecolors="black",
           linewidths=0.5, zorder=4, label="Kept")

# Running best
running_max = valid["composite"].cummax()
ax.step(valid.index, running_max, where="post", color="#27ae60", linewidth=2,
        alpha=0.7, zorder=3, label="Running best")

# Baseline reference line
ax.axhline(y=baseline, color="gray", linestyle="--", alpha=0.5, label="Baseline")

ax.set_xlabel("Experiment #")
ax.set_ylabel("Composite Score (higher is better)")
ax.set_title(f"RFL Autoresearch: {len(df)} Experiments")
ax.legend()
ax.grid(True, alpha=0.2)
plt.tight_layout()
plt.savefig("progress.png", dpi=150, bbox_inches="tight")
plt.show()
```

```python
# Top improvements
kept_df = df[df["status"] == "keep"].copy()
kept_df["prev_score"] = kept_df["composite"].shift(1)
kept_df["delta"] = kept_df["composite"] - kept_df["prev_score"]
hits = kept_df.iloc[1:].sort_values("delta", ascending=False)

print(f"{'Rank':>4}  {'Delta':>8}  {'Score':>8}  Description")
print("-" * 80)
for rank, (_, row) in enumerate(hits.iterrows(), 1):
    print(f"{rank:4d}  {row['delta']:+.6f}  {row['composite']:.6f}  {row['description']}")
```
